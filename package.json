{
  "name": "gamevault-scanner",
  "version": "1.1.0",
  "description": "GameVault Scanner - Escáner automático de videojuegos instalados en tu PC",
  "main": "./out/main/index.js",
  "author": "Enryuuh",
  "license": "MIT",
  "scripts": {
    "dev": "unset ELECTRON_RUN_AS_NODE && electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config"
  },
  "dependencies": {
    "lucide-react": "^0.474.0",
    "recharts": "^2.15.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/asar": "^3.4.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.0",
    "electron-vite": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.gamevault-scanner.app",
    "productName": "GameVault Scanner",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "!node_modules"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "sign": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
